# =====================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Mitchell Technology Group Portal
# =====================================================
# Copy this file to .env.production and update all values

# =====================================================
# Django Core Settings
# =====================================================
SECRET_KEY=generate-a-secure-50-char-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =====================================================
# Database Configuration
# =====================================================
DB_NAME=mtg_portal
DB_USER=mtg_user
DB_PASSWORD=secure-database-password-change-me
DB_HOST=db
DB_PORT=5432
# For managed databases (Render, AWS RDS, etc.):
# DATABASE_URL=postgres://user:password@host:port/dbname

# =====================================================
# Redis / Celery
# =====================================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =====================================================
# Stripe Payment Processing
# =====================================================
STRIPE_PUBLIC_KEY=pk_live_your_live_public_key
STRIPE_SECRET_KEY=sk_live_your_live_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_live_webhook_secret

# =====================================================
# Email Configuration (SMTP)
# =====================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_smtp_username
EMAIL_HOST_PASSWORD=your_smtp_password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# =====================================================
# AWS S3 Storage (Optional - for static/media files)
# =====================================================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# =====================================================
# Video Meeting Integrations
# =====================================================
# Zoom
# ZOOM_API_KEY=your_zoom_api_key
# ZOOM_API_SECRET=your_zoom_api_secret

# Google Meet (using Google Calendar API)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# =====================================================
# Security Settings
# =====================================================
# Set to False if behind a load balancer that terminates SSL
SECURE_SSL_REDIRECT=True

# =====================================================
# Logging
# =====================================================
DJANGO_LOG_LEVEL=WARNING
LOG_FILE=/var/log/mtg_portal/error.log

# =====================================================
# Sentry Error Tracking (Optional)
# =====================================================
# SENTRY_DSN=https://your_sentry_dsn
